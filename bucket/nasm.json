{
    "version": "3.02",
    "description": "80x86 and x86-64 assembler designed for portability and modularity.",
    "homepage": "https://www.nasm.us",
    "license": "BSD-2-Clause",
    "extract_dir": "nasm-3.02",
    "architecture": {
        "64bit": {
            "url": "http://www.nasm.us/pub/nasm/releasebuilds/3.02/win64/nasm-3.02-win64.zip",
            "hash": "161d0bfaff53c2f9e9f3e69fd0672323ebabafd1268976a5cec11be92a19aee7"
        },
        "32bit": {
            "url": "http://www.nasm.us/pub/nasm/releasebuilds/3.02/win32/nasm-3.02-win32.zip",
            "hash": "dca7d736580aafcf88a07838bb597a4f093fa157e56ce522891e86ab0a37c949"
        }
    },
    "bin": [
        "nasm.exe",
        "ndisasm.exe",
        "rdoff/ldrdf.exe",
        "rdoff/rdf2bin.exe",
        "rdoff/rdf2com.exe",
        "rdoff/rdf2ihx.exe",
        "rdoff/rdf2ith.exe",
        "rdoff/rdf2srec.exe",
        "rdoff/rdfdump.exe",
        "rdoff/rdflib.exe",
        "rdoff/rdx.exe"
    ],
    "env_set": {
        "NASM_PREFIX": "$dir\\"
    },
    "checkver": {
        "url": "https://nasm.us/doc/nasmdocc.html",
        "regex": "version ([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "http://www.nasm.us/pub/nasm/releasebuilds/$version/win64/nasm-$version-win64.zip"
            },
            "32bit": {
                "url": "http://www.nasm.us/pub/nasm/releasebuilds/$version/win32/nasm-$version-win32.zip"
            }
        },
        "extract_dir": "nasm-$version"
    }
}
